bind:
    ubind utype
    sensor flag @unit @flag
    sensor ctrl @unit @controlled
    jump claim equal ctrl 0         # uncontrolled — claim regardless of flag
    jump skip notEqual flag 0       # controlled + flagged — skip, next cycle
    # fall-through: controlled but unflagged (bad foreign script) — claim it
claim:
    ucontrol flag 0                 # replace 0 with actual key when used in context
skip:
