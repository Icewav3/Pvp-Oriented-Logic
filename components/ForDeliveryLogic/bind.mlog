bind:
    ubind utype
    sensor ctrl @unit @controlled
    jump claim equal ctrl 0 #if no one uses = we use
    #also if its not used we dont care abt flag so we can skip that
    sensor flag @unit @flag
    jump claim equal flag 0
    #if flag not 0 then STOP STEALING
    end
claim:
    #flag ur unit properly and then do stuff
    ucontrol flag @time