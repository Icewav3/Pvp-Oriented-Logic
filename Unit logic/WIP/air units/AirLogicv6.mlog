sensor ux @unit @x
sensor uy @unit @y
op add sx ux tx
op div sx sx 2
op add sy uy ty
op div sy sy 2
jump 115 equal found false
jump 109 notEqual bait true
ucontrol getBlock tx ty null t 0
sensor sh t @shooting
jump 112 equal sh true
ucontrol approach tx ty r 0 0
ucontrol target sx sy 1 0 0
end
