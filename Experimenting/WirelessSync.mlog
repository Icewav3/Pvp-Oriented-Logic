jump booted strictEqual init true
set creator Icewave
set interval 5
booted:
bind_loop:
    ubind unit_type
check_unit:
    sensor flag @unit @flag
    sensor ctrl @unit @controlled
    jump claim_unit equal ctrl 0
    end

#potential issue, first unit we bind may controlled by another proc which doesn't properly flag
claim_unit:
    sensor ctrller @unit @controller 
    read should_sync ctrller "creator"
    
ignore:


